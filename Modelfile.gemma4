# Modelfile for qcgemma4-st
# Gemma 4 4B fine-tuned quality checker for Bethesda Starfield Ukrainian localization.
# Trained on scripts/qc_dataset_sharegpt.jsonl (14 928 examples, 16 issue codes).
#
# To register with Ollama:
#   ollama create qcgemma4-st -f Modelfile.gemma4
#
# IMPORTANT — parameter precedence:
#   These options are NOT overridden by any app call — Modelfile values are
#   always active:
#     min_p, repeat_last_n
#
# The app always supplies the system prompt at inference time; the SYSTEM
# directive below is the fallback for direct `ollama run` use only.

FROM /home/home/.unsloth/studio/exports/gemma-4-e4b-it-unsloth-bnb-4bit-gguf/gemma-4-e4b-it.Q4_K_M.gguf

# ── Chat template (Gemma 4 format) ──────────────────────────────────────────
TEMPLATE "{{ if .System }}<start_of_turn>system
{{ .System }}<end_of_turn>
{{ end }}{{ if .Prompt }}<start_of_turn>user
{{ .Prompt }}<end_of_turn>
{{ end }}<start_of_turn>model
{{ .Response }}<end_of_turn>"

# ── System prompt ────────────────────────────────────────────────────────────
# Matches the system turn used in qc_dataset_sharegpt.jsonl training data exactly.
SYSTEM "You are a quality checker for Bethesda Starfield Ukrainian game localization. Given a source string and its Ukrainian translation, detect quality issues.

Issue codes to detect:
  MISSING_TAG        — game format tag present in source but absent in translation
  EXTRA_TAG          — tag in translation not present in source
  SOURCE_LANGUAGE_LEAK — Russian characters (ы/э/ё/ъ) or Russian words in Ukrainian output
  ENGLISH_LEAK       — untranslated English words remaining in Ukrainian output
  UNTRANSLATED       — translation is identical to the source
  EMPTY_TRANSLATION  — translation is empty or whitespace-only
  SUSPICIOUSLY_SHORT — translation is <20% the length of the source
  SUSPICIOUSLY_LONG  — translation is >500% the length of the source
  AI_ARTIFACT        — AI commentary prefix (Note:, Translation:, Переклад:, etc.)
  REPETITIVE_CONTENT — same phrase repeated 3+ times (hallucination)
  MISSING_NEWLINES   — source has \\n but translation has none
  NEWLINE_COUNT_MISMATCH — newline count differs between source and translation
  MISSING_NUMBER     — standalone number in source absent from translation
  LOW_UKRAINIAN_COVERAGE — too few recognized Ukrainian words (<25%)
  CASE_MISMATCH      — source starts uppercase, translation starts lowercase
  TRANSLATION_TRUNCATED — translation is a cut-off prefix of the source

Output for clean translation:
VERDICT: GOOD

Output for problematic translation:
VERDICT: ISSUES_FOUND
CODES: CODE1, CODE2
SEVERITY: error|warning|info
DETAILS:
- [CODE] description
ACTION: AUTOFIX|RETRANSLATE"

# ── Generation parameters ────────────────────────────────────────────────────

# Near-deterministic for consistent, reproducible classification.
PARAMETER temperature 0.0

# QC responses are short structured text (VERDICT + CODES + DETAILS + ACTION).
# 300 tokens covers the longest plausible multi-issue response.
PARAMETER num_predict 300

# Context window: enough for the longest Bethesda strings (books, terminal notes)
# plus the system prompt.  8 192 is sufficient for QC use; raise to 16 384 if
# you run into context-length errors on very long strings.
PARAMETER num_ctx 8192

# Standard sampling parameters.
PARAMETER top_k 10
PARAMETER top_p 0.9

# min_p: complement to top_p — discard tokens below 2% of the top token's
# probability.  At temperature 0 this is mostly inactive but acts as a
# safety guard against degenerate outputs.
PARAMETER min_p 0.02

# No repeat penalty — the structured output format requires repeating fixed
# keyword patterns (VERDICT, CODES, SEVERITY, DETAILS, ACTION) on every call.
PARAMETER repeat_penalty 1.0

# ── Stop tokens ──────────────────────────────────────────────────────────────
PARAMETER stop <end_of_turn>
PARAMETER stop <start_of_turn>
PARAMETER stop user:
PARAMETER stop model:
PARAMETER stop <|user|>
PARAMETER stop <|model|>
